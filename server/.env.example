# Copy this file to .env and fill in real values before deploying.

# Required
JWT_SECRET=            # generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
CLIENT_URL=http://localhost:5173

# Admin login — set these explicitly so credentials aren't auto-generated on first boot
ADMIN_EMAIL=admin@parkavejewelers.com
ADMIN_PASSWORD=

# Stripe (stripe.com dashboard -> Developers -> API keys)
STRIPE_SECRET_KEY=
# After deploying, create a webhook in the Stripe dashboard pointed at
# https://yourdomain.com/api/checkout/webhook for the "checkout.session.completed" event,
# then paste its signing secret here.
STRIPE_WEBHOOK_SECRET=

# Google Sign-In (console.cloud.google.com -> APIs & Services -> Credentials -> OAuth client ID)
GOOGLE_CLIENT_ID=

# Abandoned-cart reminder emails (resend.com -> API Keys)
# EMAIL_FROM must be an address on a domain you've verified in Resend (Domains -> Add Domain,
# then add the DNS records they give you at your registrar). Until that's done, leave EMAIL_FROM
# unset — it falls back to Resend's shared sandbox address, which only delivers to the email
# your Resend account itself is registered with, useful for testing but not for real customers.
RESEND_API_KEY=
EMAIL_FROM=
# How long after an unpaid checkout to wait before emailing a reminder. Default 60.
ABANDONED_CART_DELAY_MINUTES=60

PORT=5001
NODE_ENV=production

# If deployed on a host with an ephemeral filesystem (e.g. Render's free tier wipes
# local disk on every redeploy), point these at a mounted persistent disk instead.
# Leave unset for local dev — they default to folders inside server/.
# DB_PATH=/var/data/park_ave.db
# UPLOADS_DIR=/var/data/uploads
